# Supabase project URL (already set up): https://mtypiwbnqfzifrdmmiqy.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://mtypiwbnqfzifrdmmiqy.supabase.co

# Supabase publishable (anon) key — safe to ship to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_me_with_your_key

# Public site URL (used for auth redirects). In dev, http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Maps Platform — enable Places API + Maps JavaScript API (Places library).
# Same key can be used as NEXT_PUBLIC_* for Autocomplete and server-side for Place Details.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_API_KEY=
